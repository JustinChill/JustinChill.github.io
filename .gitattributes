# Set default behavior to automatically normalize line endings for all text files.
* text=auto

# Force files that must use LF (UNIX) line endings
*.sh text eol=lf
*.bash text eol=lf

# Force files that must use CRLF (Windows) line endings
*.bat text eol=crlf
*.cmd text eol=crlf

# Mark web assets and binary formats to prevent line ending normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.otf binary
*.ttf binary
*.eot binary

# SVG files are text-based markup
*.svg text
